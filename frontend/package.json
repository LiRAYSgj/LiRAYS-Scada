{
  "name": "scada",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "start": "node build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "prettier --check . && eslint .",
    "format": "prettier --write .",
    "test:unit": "vitest",
    "test": "npm run test:unit -- --run",
    "test:coverage": "npm run test:unit -- --run --coverage",
    "demo:ws": "tsx demo/api-server/src/server.ts",
    "generate:proto": "mkdir -p ./src/lib/proto && protoc --plugin=protoc-gen-ts_proto=./node_modules/.bin/protoc-gen-ts_proto --ts_proto_out=./src/lib/proto --ts_proto_opt=esModuleInterop=true -I=../proto ../proto/namespace/*.proto"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.2",
    "@eslint/js": "^9.39.2",
    "@fontsource-variable/inter": "^5.2.8",
    "@internationalized/date": "^3.12.0",
    "@lucide/svelte": "^1.7.0",
    "@sveltejs/adapter-node": "^5.5.4",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.50.2",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.1.18",
    "@testing-library/svelte": "^5.3.1",
    "@types/node": "^24",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.0.18",
    "bits-ui": "^2.16.5",
    "clsx": "^2.1.1",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.14.0",
    "globals": "^17.3.0",
    "jsdom": "^28.1.0",
    "jsrepo": "^3.7.0",
    "mode-watcher": "^1.1.0",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.4.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "shadcn-svelte": "^1.2.7",
    "svelte": "^5.51.0",
    "svelte-check": "^4.4.2",
    "svelte-sonner": "^1.1.0",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.1.18",
    "ts-proto": "^2.11.5",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.11.0",
    "@xyflow/svelte": "^1.5.1",
    "dotenv": "^17.3.1",
    "formsnap": "^2.0.1",
    "lucide-svelte": "^0.577.0",
    "monaco-editor": "^0.55.1",
    "sveltekit-superforms": "^2.30.1",
    "ws": "^8.19.0",
    "zod": "^4.3.6"
  }
}
