<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>Label</key>
	<string>com.lirays.scada</string>
	<key>ProgramArguments</key>
	<array>
		<string>/usr/local/bin/lirays-scada</string>
		<string>--config</string>
		<string>/Library/LiRAYS-Scada/settings.yaml</string>
	</array>
	<key>RunAtLoad</key>
	<true/>
	<key>KeepAlive</key>
	<true/>
	<key>UserName</key>
	<string>root</string>
	<key>StandardOutPath</key>
	<string>/Library/Logs/LiRAYS-Scada/lirays-scada.out.log</string>
	<key>StandardErrorPath</key>
	<string>/Library/Logs/LiRAYS-Scada/lirays-scada.err.log</string>
	<key>WorkingDirectory</key>
	<string>/Library/LiRAYS-Scada</string>
	<key>EnvironmentVariables</key>
	<dict>
		<key>DATA_DIR</key>
		<string>/Library/LiRAYS-Scada/data_dir</string>
	</dict>
</dict>
</plist>
